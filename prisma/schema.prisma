// ChatBarber — Prisma Schema
// Scalable multi-tenant architecture for 100k+ barber shop owners

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  OWNER
  MANAGER
  STAFF
  CLIENT
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELLED
  EXPIRED
  TRIAL
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ClientType {
  SUBSCRIBER
  WALK_IN
}

enum CostType {
  FIXED
  VARIABLE
}

enum CashEntryType {
  INCOME
  EXPENSE
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
}

enum GamificationLevel {
  BRONZE
  PRATA
  OURO
  PLATINA
  DIAMANTE
  RUBI
}

enum BannerType {
  INTERNAL
  MINISITE
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  PIX
  TRANSFER
  OTHER
}

enum CommissionStatus {
  PENDING
  PAID
}

enum ReferralStatus {
  PENDING
  CONVERTED
  EXPIRED
}

// ─────────────────────────────────────────────────────────────
// OWNERS (Donos de sistema SaaS)
// ─────────────────────────────────────────────────────────────

model Owner {
  id                String    @id @default(cuid())
  name              String
  email             String    @unique
  passwordHash      String
  phone             String?
  avatarUrl         String?
  role              UserRole  @default(OWNER)
  isActive          Boolean   @default(true)
  apiKey            String    @unique @default(cuid())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  stores            Store[]
  subscriptionPlans SubscriptionPlan[]
  banners           Banner[]
  campaigns         Campaign[]
  referralCampaigns ReferralCampaign[]
  celcashToken      String?
  celcashPublicToken String?
  aiContext         AiContext?

  @@map("owners")
}

// ─────────────────────────────────────────────────────────────
// STORES (Lojas/Unidades)
// ─────────────────────────────────────────────────────────────

model Store {
  id              String    @id @default(cuid())
  ownerId         String
  name            String
  slug            String    @unique  // chatbarber.com.br/[slug]
  email           String?
  phone           String?
  address         String?
  city            String?
  state           String?
  zipCode         String?
  logoUrl         String?
  primaryColor    String    @default("#f97316")
  colorSubscriber String    @default("#166534")
  colorRegular    String    @default("#475569")
  colorDefaulter  String    @default("#991B1B")
  loginBackgroundUrl String?   
  brandingFaviconUrl String?
  description     String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  owner           Owner           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  businessHours   BusinessHour[]
  staff           Staff[]
  services        Service[]
  products        Product[]
  appointments    Appointment[]
  costs           Cost[]
  cashEntries     CashEntry[]
  clientStores    ClientStore[]
  banners         Banner[]
  npsRatings      NpsRating[]
  waitlistEntries WaitlistEntry[]
  potDistributions PotDistribution[]

  @@index([ownerId])
  @@map("stores")
}

// ─────────────────────────────────────────────────────────────
// BUSINESS HOURS
// ─────────────────────────────────────────────────────────────

model BusinessHour {
  id          String    @id @default(cuid())
  storeId     String
  dayOfWeek   Int       // 0=Sunday, 1=Monday, ..., 6=Saturday
  isOpen      Boolean   @default(true)
  openTime    String    // "08:00"
  closeTime   String    // "20:00"
  breakStart  String?   // "12:00"
  breakEnd    String?   // "13:00"
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, dayOfWeek])
  @@map("business_hours")
}

// ─────────────────────────────────────────────────────────────
// STAFF (Barbeiros/Profissionais)
// ─────────────────────────────────────────────────────────────

model Staff {
  id                  String            @id @default(cuid())
  storeId             String
  name                String
  email               String?
  phone               String?
  passwordHash        String?
  avatarUrl           String?
  role                UserRole          @default(STAFF)
  commissionPercent   Float             @default(0)   // % de comissão
  gamificationLevel   GamificationLevel @default(BRONZE)
  gamificationPoints  Int               @default(0)
  isActive            Boolean           @default(true)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  // Relations
  store               Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  staffServices       StaffService[]
  appointments        Appointment[]
  commissions         Commission[]
  campaignEntries     CampaignEntry[]
  npsRatings          NpsRating[]
  referralCampaignLinks ReferralLink[]

  @@index([storeId])
  @@map("staff")
}

// ─────────────────────────────────────────────────────────────
// CLIENTS (Clientes dos donos de barbearia)
// ─────────────────────────────────────────────────────────────

model Client {
  id            String      @id @default(cuid())
  ownerId       String      // Dono do sistema ao qual este cliente pertence
  name          String
  email         String?
  passwordHash  String?
  phone         String?
  cpf           String?
  avatarUrl     String?
  birthDate     DateTime?
  clientType    ClientType  @default(WALK_IN)
  totalSpent    Float       @default(0)
  isActive      Boolean     @default(true)
  isDefaulter   Boolean     @default(false) // Indica se o cliente está inadimplente (pagamento de assinatua atrasado/falho)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  clientStores      ClientStore[]
  appointments      Appointment[]
  subscription      ClientSubscription?
  waitlistEntries   WaitlistEntry[]
  npsRatings        NpsRating[]
  referralLinks     ReferralLink[]     @relation("ClientPromoter")
  referralConverted ReferralConversion? @relation("ConvertedClient")

  @@unique([ownerId, email])
  @@unique([ownerId, cpf])
  @@index([ownerId])
  @@map("clients")
}

// Vínculo Cliente ↔ Loja (cliente pode visitar múltiplas lojas do mesmo owner)
model ClientStore {
  id        String    @id @default(cuid())
  clientId  String
  storeId   String
  firstVisit DateTime @default(now())
  lastVisit  DateTime @default(now())

  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  store     Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([clientId, storeId])
  @@map("client_stores")
}

enum WaitlistStatus {
  PENDING
  FULFILLED
  CANCELLED
}

model WaitlistEntry {
  id              String      @id @default(cuid())
  storeId         String
  clientId        String
  requestedDate   DateTime
  notes           String?
  status          WaitlistStatus @default(PENDING)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  store           Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  client          Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([storeId, status])
  @@map("waitlist_entries")
}

// ─────────────────────────────────────────────────────────────
// SERVICES & PRODUCTS
// ─────────────────────────────────────────────────────────────

model Service {
  id              String    @id @default(cuid())
  storeId         String
  name            String
  description     String?
  price           Float
  durationMinutes Int       @default(30)
  category        String?
  isActive        Boolean   @default(true)
  imageUrl        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  store           Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  staffServices   StaffService[]
  appointmentItems AppointmentItem[]
  subscriptionPlanServices SubscriptionPlanService[]

  @@index([storeId])
  @@map("services")
}

model StaffService {
  staffId     String
  serviceId   String

  staff       Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service     Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([staffId, serviceId])
  @@map("staff_services")
}

model Product {
  id            String    @id @default(cuid())
  storeId       String
  name          String
  description   String?
  sku           String?
  priceRetail   Float
  priceCost     Float?
  stockQty      Int       @default(0)
  imageUrl      String?
  category      String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  store         Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  appointmentItems AppointmentItem[]

  @@index([storeId])
  @@map("products")
}

// ─────────────────────────────────────────────────────────────
// APPOINTMENTS (Agendamentos)
// ─────────────────────────────────────────────────────────────

model Appointment {
  id              String            @id @default(cuid())
  storeId         String
  clientId        String
  staffId         String
  status          AppointmentStatus @default(SCHEDULED)
  scheduledAt     DateTime
  durationMinutes Int               @default(30)
  totalAmount     Float             @default(0)
  paymentMethod   PaymentMethod?
  notes           String?
  cancelledAt     DateTime?
  completedAt     DateTime?
  isSubscription  Boolean           @default(false)
  fichasCount     Int               @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  store           Store               @relation(fields: [storeId], references: [id])
  client          Client              @relation(fields: [clientId], references: [id])
  staff           Staff               @relation(fields: [staffId], references: [id])
  items           AppointmentItem[]
  commission      Commission?
  npsRating       NpsRating?

  @@index([storeId, scheduledAt])
  @@index([clientId])
  @@index([staffId])
  @@map("appointments")
}

model AppointmentItem {
  id              String    @id @default(cuid())
  appointmentId   String
  serviceId       String?
  productId       String?
  quantity        Int       @default(1)
  unitPrice       Float
  totalPrice      Float

  appointment     Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service         Service?    @relation(fields: [serviceId], references: [id])
  product         Product?    @relation(fields: [productId], references: [id])

  @@map("appointment_items")
}

// ─────────────────────────────────────────────────────────────
// SUBSCRIPTIONS (Planos de Assinatura)
// ─────────────────────────────────────────────────────────────

model SubscriptionPlan {
  id              String    @id @default(cuid())
  ownerId         String
  name            String
  description     String?
  price           Float
  potAmount       Float     @default(0)    // Valor da mensalidade que vai para o "pote"
  chipsPerService Int       @default(1)    // Quantidade de fichas por atendimento
  billingCycleDay Int       @default(1)
  intervalDays    Int       @default(30)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  owner                    Owner                     @relation(fields: [ownerId], references: [id])
  services                 SubscriptionPlanService[]
  clientSubscriptions      ClientSubscription[]

  @@map("subscription_plans")
}

model SubscriptionPlanService {
  planId      String
  serviceId   String
  usageLimit  Int?  // null = ilimitado

  plan        SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  service     Service          @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([planId, serviceId])
  @@map("subscription_plan_services")
}

model ClientSubscription {
  id          String             @id @default(cuid())
  clientId    String             @unique
  planId      String
  status      SubscriptionStatus @default(ACTIVE)
  startDate   DateTime           @default(now())
  endDate     DateTime?
  renewedAt   DateTime?
  cancelledAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  client      Client           @relation(fields: [clientId], references: [id])
  plan        SubscriptionPlan @relation(fields: [planId], references: [id])

  @@map("client_subscriptions")
}

// ─────────────────────────────────────────────────────────────
// FINANCIAL — Costs & Cash
// ─────────────────────────────────────────────────────────────

model Cost {
  id          String    @id @default(cuid())
  storeId     String
  name        String
  type        CostType
  amount      Float
  dueDay      Int?      // dia do mês (para fixos)
  referenceMonth String? // "2026-03" (para variáveis)
  notes       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@map("costs")
}

model CashEntry {
  id            String        @id @default(cuid())
  storeId       String
  type          CashEntryType
  amount        Float
  description   String
  paymentMethod PaymentMethod @default(CASH)
  entryDate     DateTime      @default(now())
  createdAt     DateTime      @default(now())

  store         Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, entryDate])
  @@map("cash_entries")
}

// ─────────────────────────────────────────────────────────────
// COMMISSIONS
// ─────────────────────────────────────────────────────────────

model Commission {
  id              String           @id @default(cuid())
  staffId         String
  appointmentId   String           @unique
  grossAmount     Float
  commissionRate  Float            // % aplicada
  commissionAmount Float
  status          CommissionStatus @default(PENDING)
  paidAt          DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  staff           Staff       @relation(fields: [staffId], references: [id])
  appointment     Appointment @relation(fields: [appointmentId], references: [id])

  @@index([staffId])
  @@map("commissions")
}

// ─────────────────────────────────────────────────────────────
// CAMPAIGNS & GAMIFICATION
// ─────────────────────────────────────────────────────────────

model Campaign {
  id          String         @id @default(cuid())
  ownerId     String
  name        String
  description String?
  status      CampaignStatus @default(DRAFT)
  startDate   DateTime
  endDate     DateTime
  targetAmount Float?        // meta em R$
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  owner       Owner             @relation(fields: [ownerId], references: [id])
  entries     CampaignEntry[]

  @@map("campaigns")
}

model CampaignEntry {
  id            String    @id @default(cuid())
  campaignId    String
  staffId       String
  appointmentId String?
  saleAmount    Float
  points        Int       @default(0)
  createdAt     DateTime  @default(now())

  campaign      Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  staff         Staff     @relation(fields: [staffId], references: [id])

  @@index([campaignId, staffId])
  @@map("campaign_entries")
}

// ─────────────────────────────────────────────────────────────
// BANNERS
// ─────────────────────────────────────────────────────────────

model Banner {
  id          String     @id @default(cuid())
  ownerId     String
  storeId     String?
  title       String
  imageUrl    String
  linkUrl     String?
  type        BannerType @default(INTERNAL)
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  owner       Owner   @relation(fields: [ownerId], references: [id])
  store       Store?  @relation(fields: [storeId], references: [id])

  @@map("banners")
}

// ─────────────────────────────────────────────────────────────
// NPS — Net Promoter Score
// ─────────────────────────────────────────────────────────────

model NpsRating {
  id              String    @id @default(cuid())
  appointmentId   String    @unique
  storeId         String
  staffId         String
  clientId        String
  score           Int       // 1–10
  comment         String?
  createdAt       DateTime  @default(now())

  appointment     Appointment @relation(fields: [appointmentId], references: [id])
  store           Store       @relation(fields: [storeId], references: [id])
  staff           Staff       @relation(fields: [staffId], references: [id])
  client          Client      @relation(fields: [clientId], references: [id])

  @@index([staffId])
  @@index([storeId])
  @@map("nps_ratings")
}

// ─────────────────────────────────────────────────────────────
// POT DISTRIBUTIONS (Sistema de Pote)
// ─────────────────────────────────────────────────────────────

model PotDistribution {
  id              String    @id @default(cuid())
  storeId         String
  month           Int       // 1-12
  year            Int
  totalPotAmount  Float     // Valor total no pote (soma do potAmount das assinaturas ativas)
  totalFichas     Int       // Soma de todas as fichas geradas no mês
  valuePerFicha   Float     // totalPotAmount / totalFichas
  status          String    @default("PENDING") // PENDING, PAID
  createdAt       DateTime  @default(now())

  store           Store     @relation(fields: [storeId], references: [id])

  @@unique([storeId, month, year])
  @@map("pot_distributions")
}

// ─────────────────────────────────────────────────────────────
// INDICA AÍ — Referral Campaigns
// ─────────────────────────────────────────────────────────────

model ReferralCampaign {
  id                    String         @id @default(cuid())
  ownerId               String
  name                  String
  description           String?
  status                CampaignStatus @default(DRAFT)
  startDate             DateTime
  endDate               DateTime?
  // Comissões
  promoterCommissionType  String       @default("PERCENT") // PERCENT | FIXED
  promoterCommissionValue Float        @default(0)
  newClientDiscountType   String       @default("PERCENT")
  newClientDiscountValue  Float        @default(0)
  staffCommissionType     String       @default("PERCENT")
  staffCommissionValue    Float        @default(0)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  owner                 Owner              @relation(fields: [ownerId], references: [id])
  links                 ReferralLink[]

  @@map("referral_campaigns")
}

model ReferralLink {
  id              String          @id @default(cuid())
  campaignId      String
  promoterClientId String         // Cliente assinante que vai indicar
  staffId         String          // Barbeiro responsável pelo promotor
  code            String          @unique @default(cuid())
  status          CampaignStatus  @default(ACTIVE)
  createdAt       DateTime        @default(now())

  campaign        ReferralCampaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  promoterClient  Client             @relation("ClientPromoter", fields: [promoterClientId], references: [id])
  staff           Staff              @relation(fields: [staffId], references: [id])
  conversions     ReferralConversion[]

  @@index([campaignId])
  @@map("referral_links")
}

model ReferralConversion {
  id              String         @id @default(cuid())
  linkId          String
  newClientId     String         @unique
  status          ReferralStatus @default(PENDING)
  convertedAt     DateTime?
  promoterPaid    Boolean        @default(false)
  staffPaid       Boolean        @default(false)
  createdAt       DateTime       @default(now())

  link            ReferralLink   @relation(fields: [linkId], references: [id])
  newClient       Client         @relation("ConvertedClient", fields: [newClientId], references: [id])

  @@map("referral_conversions")
}

// ─────────────────────────────────────────────────────────────
// AI CONTEXT (para treinamento de IA)
// ─────────────────────────────────────────────────────────────

model AiContext {
  id              String    @id @default(cuid())
  ownerId         String    @unique
  systemPrompt    String?   @db.Text
  trainingData    Json?     // dados consumidos automaticamente
  lastSyncedAt    DateTime?
  whatsappToken   String?
  evolutionApiUrl String?
  openaiKey       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  owner           Owner     @relation(fields: [ownerId], references: [id])

  @@map("ai_contexts")
}
